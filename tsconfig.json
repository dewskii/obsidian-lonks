{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2019"],
		"module": "ESNext",
		"target": "ES2019",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"strict": true,
		"isolatedModules": true,
		"ignoreDeprecations": "6.0",
		"noUnusedLocals": false,
		"noUnusedParameters": false
	},
	"include": ["**/*.ts"]
}
