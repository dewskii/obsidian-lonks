{
	"name": "lonks",
	"version": "0.2.3",
	"description": "Automatically suggest and create internal links when typing matching note names",
	"main": "main.js",
	"scripts": {
		"dev": "bun run esbuild.config.mjs",
		"build": "bun run esbuild.config.mjs production",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"stage:local:prep": "dotenv -- mkdir -p \"$DEPLOY_DIR\"",
		"stage:local": "dotenv -- cp main.js manifest.json styles.css \"$DEPLOY_DIR\"",
		"deploy:local": "dotenv -- sh -c 'bun run --sequential stage:local:prep stage:local'",
		"deploy": "dotenv -- bun run --sequential lint:fix build deploy:local",
		"release": "rm -f lonks.zip && bun run build && mkdir -p lonks && cp main.js manifest.json styles.css lonks && zip lonks.zip lonks"
	},
	"keywords": ["obsidian", "plugin", "internal-links", "auto-complete"],
	"author": "Eric Dew",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@codemirror/autocomplete": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@types/node": "^25.3.0",
		"@wdio/cli": "^9.24.0",
		"builtin-modules": "3.2.0",
		"esbuild": "^0.27.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"dotenv-cli": "^11.0.0"
	}
}
